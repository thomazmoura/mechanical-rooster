# Settings for docker-compose.prod.yml. Copy to .env and fill in (.env is gitignored).

# PostgreSQL password (also embedded in the API's connection string).
POSTGRES_PASSWORD=

# JWT signing key — generate one with: openssl rand -base64 48
JWT_KEY=

# Google OAuth *Web* client ID (same value as ROOSTER_GOOGLE_WEB_CLIENT_ID in the
# app build; see the README's OAuth section). Leave empty to rely on dev bypass only.
GOOGLE_CLIENT_ID=

# Optional: prebuilt multi-arch image to run instead of building locally,
# e.g. ghcr.io/<you>/mechanicalrooster-api. Empty = build from ./backend.
#API_IMAGE=
